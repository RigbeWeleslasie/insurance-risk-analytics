# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — actual files tracked by DVC, not Git
# .dvc pointer files and subdirectory .gitignore files are committed to Git.
# Negation must un-ignore directories before un-ignoring files within them.
/data/*
!/data/*.dvc
!/data/.gitignore
!/data/processed/
/data/processed/*
!/data/processed/*.dvc
!/data/processed/.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# Coverage
.coverage
htmlcov/
.pytest_cache/

# DVC internals — cache and local remote not committed
.dvc/tmp/
.dvc/plots/
.dvc-remote/
