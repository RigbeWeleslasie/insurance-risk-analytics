# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — actual files tracked by DVC, not Git
# DVC auto-generates data/.gitignore to exclude raw files;
# .dvc pointer files and data/.gitignore are committed to Git.
/data/**
!/data/**/.gitignore
!/data/**/*.dvc

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# Coverage
.coverage
htmlcov/
.pytest_cache/

# DVC internals — cache and local remote not committed
.dvc/tmp/
.dvc/plots/
.dvc-remote/
